// kind=shader
uniform float2 u_canvasSize;
uniform half4  u_tint;

float sdRoundRect(vec2 uv, vec2 halfSize, float r) {
    vec2 d = abs(uv) - (halfSize - r);
    float outsideDist = length(max(d, 0.0));
    float insideDist = min(max(d.x, d.y), 0.0);
    return outsideDist + insideDist - r;
}

half4 main(float2 curP) {
    // 1. ПІДГОТОВКА КООРДИНАТ
    vec2 center = u_canvasSize * 0.5;
    vec2 uv = curP - center;
    float minCanvas = min(u_canvasSize.x, u_canvasSize.y);

    // 2. ВХІДНІ УМОВИ
    float aspectRatio = 1.618;          
    float shadowSpreadPct = 0.05;       
    float shadowBlurPct   = 0.08;       
    float borderThickPct  = 0.01;       
    float cornerRadiusPct = 0.20;       

    // 3. РОЗРАХУНОК ТІНІ
    float shadowSpread = minCanvas * shadowSpreadPct; 
    float shadowBlur   = minCanvas * shadowBlurPct;
    float totalShadowMargin = shadowSpread + shadowBlur;
    float availableWidth  = u_canvasSize.x - (totalShadowMargin * 2.0);
    float availableHeight = u_canvasSize.y - (totalShadowMargin * 2.0);

    // 4. ВПИСУВАННЯ ФІГУРИ
    float rectWidth;
    float rectHeight;
    float availableAspect = availableWidth / availableHeight;
    
    if (availableAspect > aspectRatio) {
        rectHeight = availableHeight;
        rectWidth  = rectHeight * aspectRatio;
    } else {
        rectWidth  = availableWidth;
        rectHeight = rectWidth / aspectRatio;
    }

    vec2 figureSize = vec2(rectWidth, rectHeight);
    vec2 halfSize   = figureSize * 0.5;

    // 5. ДИНАМІЧНІ РАДІУСИ ТА ТОВЩИНА
    float minFigureSide = min(rectWidth, rectHeight);
    float cornerRadius  = minFigureSide * cornerRadiusPct;
    float borderThickness = minCanvas * borderThickPct;

    // 6. ГЕОМЕТРІЯ (SDF)
    float dist = sdRoundRect(uv, halfSize, cornerRadius);
    float distanceToBorder = abs(dist) - (borderThickness * 0.5);
    float shadowDistance = distanceToBorder - shadowSpread;

    // 7. МАСКИ ТА КОЛЬОРИ
    float aa = 1.5; 
    float ringMask   = 1.0 - smoothstep(0.0, aa, distanceToBorder);
    float shadowMask = 1.0 - smoothstep(0.0, shadowBlur, shadowDistance);

    // --- ВАШ НОВИЙ КОД ДЛЯ КОЛЬОРОВОЇ ТІНІ (СВІТІННЯ) ---
    // 1. Задаємо базовий колір тіні (наприклад, синій неон: R=0, G=0.3, B=0.8)
    vec3 baseShadowRGB = vec3(0.0, 0.3, 0.8);
    
    // 2. Вираховуємо фінальну прозорість (максимум 80% непрозорості * маску тіні)
    float shadowAlpha = 0.8 * shadowMask;
    
    // 3. Створюємо half4, множачи RGB на alpha (Premultiplied Alpha)
    half4 shadowColor = half4(baseShadowRGB * shadowAlpha, shadowAlpha);
    // ----------------------------------------------------

    // Колір самої рамки (червоний)
    half4 ringColor = half4(1.0, 0.2, 0.2, 1.0); 

    // Комбінуємо: mix накладе червону рамку поверх синього світіння
    half4 finalColor = mix(shadowColor, ringColor, ringMask);

    return finalColor;
}