// kind=shader
uniform float2 u_canvasSize;
uniform float2 u_figureSize;
uniform vec4   u_tint;

vec4 main(float2 curP) {
  vec2  uv          = curP - u_canvasSize * 0.5;
  float t           = 3.0;                         // товщина обвідки
  float R           = u_figureSize.x * 0.5 - t;     // радіус бублика
  float aa          = 2.0;                          // згладжування країв

  float shadowBlur  = 25.0;                         // ← розмиття тіні
  float shadowSize  = 0.5*(u_canvasSize.x-u_figureSize.x)-shadowBlur;  // ← розмір тіні

  float dist = length(uv);

  // 1. Відстань до обвідки (для бублика)
  float distanceToBorder = abs(dist - R) - t * 0.5;
  // float distanceToBorder = abs(dist - u_figureSize.x * 0.5 - t + 6.0 * sin(8.0 * atan(uv.y, uv.x))) - t * 0.5;
  float ringMask = 1.0 - smoothstep(0.0, aa, distanceToBorder);

  // 2. Відстань до тіні (тільки зовні бублика)
  float shadowDistance = distanceToBorder - shadowSize;
  float shadowMask     = 1.0 - smoothstep(0.0, shadowBlur, shadowDistance);

  // 3. Кольори
  vec4 ringColor   = u_tint * ringMask;               // червоний бублик
  vec4 shadowColor = vec4(0.0, 0.0, 0.0, 0.5);        // чорна тінь (alpha можна міняти)

  // 4. Комбінуємо: спочатку тінь, потім зверху бублик
  vec4 finalColor = mix(shadowColor, ringColor, ringMask);

  // 5. Обмежуємо тінь тільки зовні (ключовий рядок!)
  finalColor.a *= max(shadowMask, ringMask);

  return finalColor;
}