// kind=shader
uniform float2 u_canvasSize;
uniform float2 u_figureSize;
uniform vec4   u_tint;

vec4 main(float2 curP) {
  vec2  uv   = curP - u_canvasSize * 0.5;
  float R    = u_figureSize.x * 0.5;   // радіус
  float t    = 40.0;                   // товщина обвідки (бордер)
  float aa   = 2.0;                    // згладжування країв

// Відстань від центру до поточного пікселя
  float dist = length(uv);

  // ←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←
  // Ось твоя ідея в коді:
  // dist - R — наскільки ми «промахнулися» повз ідеальний радіус R. 
  // (позитивне — зовні, негативне — всередині)
  // - t * 0.5 — зсуваємо межу всередину на половину товщини.
  // Тепер distanceToBorder =
  // 0.0 — коли піксель точно на середині обвідки
  // > 0 — коли піксель поза обвідкою
  // < 0 — коли піксель всередині обвідки (але ближче до краю)
  float distanceToBorder = abs(dist - R) - t * 0.5;
  // Ось як працює smoothstep(0.0, aa, x):
  // Якщо x ≤ 0.0 → повертає 0.0
  // Якщо x ≥ aa → повертає 1.0
  // Між 0 і aa — плавний перехід від 0 до 1.
  // Тому:
  // 1.0 - 0.0 = 1.0 (піксель всередині обвідки)
  // 1.0 - 1.0 = 0.0 (піксель далеко поза обвідкою)
  // Між ними — плавний перехід (м’які краї).
  float ringMask = 1.0 - smoothstep(0.0, aa, distanceToBorder);
  // ←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←

  return u_tint * ringMask;
}